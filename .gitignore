# This plugin ships a Jinja template; override a global "*.html" ignore so it
# is tracked (see ~/.gitignore_global).
!templates/*.html

# Python
__pycache__/
*.py[cod]
.venv/
*.egg-info/

# Tooling
.ruff_cache/
.mypy_cache/
.pytest_cache/

# OS
.DS_Store

# Plugin output (if testing inside a gallery)
.tag_gallery_cache.json
